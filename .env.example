# ═════════════════════════════════════════════════
# 港中深求职AI智能体 — 环境变量模板
# 复制为 .env 并填入真实值（.env 不会被提交到 Git）
# ═════════════════════════════════════════════════

# ── 数据库 (PostgreSQL + pgvector) ──
# Zeabur 部署时自动注入 POSTGRES_DATABASE_URL，无需手动设置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_ai

# ── DeepSeek — 主 Agent（对话/简历解析） ──
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── 阿里云百炼 — Embedding + Rerank ──
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Serper — 联网搜索 ──
SERPER_API_KEY=your-serper-key

# ── JWT 签名密钥 ──
JWT_SECRET=your-jwt-secret-change-me

# ── CORS 允许的前端域名（JSON 数组或逗号分隔） ──
CORS_ORIGINS=http://localhost:3000
